# Configuration for aorms-estimate-backend (read by the systemd unit).
# Uncomment and edit to override the built-in defaults, then:
#   sudo systemctl restart aorms-estimate-backend
#
# Bind address (use 0.0.0.0 to expose on the network — mind your firewall).
#ESTIMATE_HOST=127.0.0.1
# Listen port.
#ESTIMATE_PORT=8787
# SQLite database file (must be writable by the service user).
#ESTIMATE_DB=/var/lib/aorms-estimate/aorms-estimate.db
