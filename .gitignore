# --- greenfield AORMS monorepo ---
# dependencies
node_modules/
.pnpm-store/

# builds
dist/
build/
*.tsbuildinfo

# env / secrets
.env
.env.*
!.env.example
# signing keys / certificates — must never be committed
*.pem
*.key
*.p12
*.pfx
.keys/
!deploy/.env.production.example

# python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# data / volumes
data/
.idea/
.vscode/
.claude/
# pnpm postinstall (setup-carbon-kit.mjs) creates this as a symlink into
# node_modules, so match it with no trailing slash (dir-only pattern misses symlinks).
.carbon-kit

# Desktop edition installers (build output)
desktop/dist-installers/

# Locally-staged desktop installers for the /download page (large binaries)
frontend/public/downloads/
