htdocs/conf/conf.php
htdocs/conf/conf.php.old
documents/
containers/.env
*.log
*.tmp
Thumbs.db
.DS_Store

# --- greenfield AORMS monorepo ---
# dependencies
node_modules/
.pnpm-store/

# builds
dist/
# Vendored kit packages ship a committed built dist/ — keep them tracked.
!vendor/*/dist/
!vendor/*/dist/**
build/
*.tsbuildinfo

# env / secrets
.env
.env.*
!.env.example
# signing keys / certificates — must never be committed
*.pem
*.key
*.p12
*.pfx
.keys/
!deploy/.env.production.example

# python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# data / volumes
data/
dump.rdb
*.rdb
# ...but backend/src/data holds committed generated SOURCE (CPWD rate-book seed),
# not runtime volumes — keep it tracked so Docker builds have it.
!backend/src/data/
.idea/
.vscode/
.claude/

# VPS installer staging (legacy)
deploy/.installers/

# Locally-staged download binaries (if any)
frontend/public/downloads/

# Editor / agent metadata
.cursor/

# Test / coverage artifacts
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Build caches
.turbo/
.cache/
pnpm-debug.log*
