{
  "name": "@hcw/ui-kit",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "description": "HCW-UI-Kit \u2014 vendored BUILT copy of github.com/HolagundiWorks/hcwux @ 1.4.0. Do not edit here; edit upstream in the hcwux repo and re-vendor its dist/.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "default": "./dist/tokens.js"
    },
    "./token-export": {
      "types": "./dist/token-export.d.ts",
      "import": "./dist/token-export.js",
      "default": "./dist/token-export.js"
    },
    "./tokens.json": "./dist/tokens.json",
    "./tokens.css": "./dist/tokens.css",
    "./portal-chrome.scss": "./dist/portal-chrome.scss"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/material": ">=9",
    "@mui/x-data-grid": ">=9",
    "@mui/x-date-pickers": ">=9",
    "dayjs": ">=1.11",
    "react": ">=18",
    "react-dom": ">=18"
  }
}
