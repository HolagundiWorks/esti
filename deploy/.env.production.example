# ESTI AORMS — PRODUCTION environment for Docker deployment (Ubuntu + Docker, e.g. Hostinger VPS).
#
# This file is the template consumed by deploy/bootstrap.sh:
#     cp deploy/.env.production.example .env
# bootstrap.sh auto-substitutes CHANGE_ME_DOMAIN and CHANGE_ME_64_char_hex, then
# refuses to continue while any other CHANGE_ME_* placeholder remains — so you
# MUST replace every CHANGE_ME_* value below by hand before deploying.
#
# Generate strong secrets on the VPS:
#     openssl rand -hex 32      # SESSION_SECRET
#     openssl rand -base64 24   # DB / object-store passwords
#
# Service hostnames (esti-db, esti-redis, esti-minio) are the container names in
# compose.prod.yaml — do not change them unless you rename the services.
#
# Read by:  docker compose -f compose.prod.yaml up -d --build   (env_file: .env)

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=4000
# Signs session cookies. 64-char hex. bootstrap.sh fills this automatically.
SESSION_SECRET=CHANGE_ME_64_char_hex
# Marks the session cookie Secure — keep true (you serve over HTTPS via nginx).
COOKIE_SECURE=true
# Browser origin(s) permitted to make cookie-authenticated writes. Your domain
# over HTTPS. bootstrap.sh fills CHANGE_ME_DOMAIN from the value you pass it.
ALLOWED_ORIGINS=https://CHANGE_ME_DOMAIN

# ── PostgreSQL (system of record — internal only, no host port) ──────────────
POSTGRES_USER=esti
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=esti
# The password in DATABASE_URL MUST be identical to POSTGRES_PASSWORD above.
# Host is the esti-db compose service; port 5432 is internal to the network.
DATABASE_URL=postgres://esti:CHANGE_ME_db_password@esti-db:5432/esti

# ── Redis (job bus + sessions — internal only, no host port) ─────────────────
REDIS_URL=redis://esti-redis:6379
WORKER_JOB_STREAM=esti:jobs
WORKER_GROUP=esti-workers

# ── Object storage (MinIO — internal only, no host port) ─────────────────────
# Internal endpoint the backend + worker use to reach MinIO on the compose net.
S3_ENDPOINT=http://esti-minio:9000
S3_REGION=ap-south-1
S3_BUCKET=esti-documents
S3_ACCESS_KEY=esti
S3_SECRET_KEY=CHANGE_ME_object_store_secret
# Browser-reachable endpoint used to SIGN download URLs (drawings, PDFs).
# compose.prod.yaml does NOT expose MinIO to the internet, so choose one:
#   (a) Managed S3/Backblaze B2: set S3_ENDPOINT + this to the provider host and
#       drop the esti-minio service from compose.prod.yaml; OR
#   (b) Self-hosted MinIO behind your nginx: publish esti-minio :9000 on
#       127.0.0.1, add a TLS `files.CHANGE_ME_DOMAIN` (or /s3 location) proxy to
#       it, and point this there.
# Until you wire one of these, in-app file downloads will not resolve.
S3_PUBLIC_ENDPOINT=https://files.CHANGE_ME_DOMAIN

# ── First-run owner + demo workspace ─────────────────────────────────────────
# The landing "Log in to live demo" button signs in as principal@demo.aorms.in
# with SEED_DEMO_PASSWORD. The demo seed (seedDemo.ts) creates that account as an
# OWNER with a fully populated workspace. The SEED_OWNER_* values below are
# matched to that demo principal, and seed.ts is idempotent by email — so running
# both seeds yields ONE owner account (the demo login), not two.
#
#   Seed both after the stack is up (prod image has no tsx — use the compiled
#   :prod scripts that run the dist/ output with node):
#     docker compose -f compose.prod.yaml exec backend pnpm --filter @esti/backend seed:prod
#     docker compose -f compose.prod.yaml exec backend pnpm --filter @esti/backend seed:demo:prod
#
# !! SECURITY: this makes the owner login PUBLIC (demo1234 is printed on the
#    landing page). That is correct for the aorms.in public demo site. If this
#    instance will hold REAL firm data, instead set a unique SEED_OWNER_EMAIL and
#    a strong SEED_OWNER_PASSWORD, and do NOT run seed:demo.
SEED_OWNER_EMAIL=principal@demo.aorms.in
SEED_OWNER_NAME=Ar. Vihaan Sharma (Principal)
SEED_OWNER_PASSWORD=demo1234
SEED_DEMO_PASSWORD=demo1234

# ── Demo (optional external URL) ─────────────────────────────────────────────
# Landing demo cards sign in locally when empty. Set only if studio/solo run on
# separate hosts. Baked in at frontend build time — rebuild frontend after change.
# See docs/esti/DEMO-AND-HR-MODE.md.
VITE_FULL_DEMO_URL=
VITE_SOLO_DEMO_URL=
# Google Form — "Register interest" link on the marketing landing page.
VITE_FEEDBACK_FORM_URL=

# ── After first deploy — demo workspaces (public demo site only) ─────────────
# Migrations run automatically on backend startup (incl. 0042_site_metrics).
# Seed studio + solo demo accounts (prod compiled scripts, no tsx):
#
#   docker compose -f compose.prod.yaml exec backend pnpm --filter @esti/backend seed:prod
#   docker compose -f compose.prod.yaml exec backend pnpm --filter @esti/backend seed:demo:prod
#   docker compose -f compose.prod.yaml exec backend pnpm --filter @esti/backend seed:demo:solo:prod
#
# Studio demo: principal@demo.aorms.in / demo1234  (pnpm seed:demo)
# Solo demo:   solo@demo.aorms.in / demo1234       (pnpm seed:demo:solo)
#
# Rebuild frontend after changing VITE_* above:
#   bash deploy/deploy.sh
