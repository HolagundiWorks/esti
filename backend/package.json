{
  "name": "@esti/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    "./router": "./src/trpc/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:alerts": "tsx src/scripts/testBuildAlerts.ts",
    "test:ai": "tsx src/scripts/testAiAgent.ts",
    "test:companion": "tsx src/scripts/testCompanion.ts",
    "test:api-smoke": "tsx src/scripts/testApiSmoke.ts",
    "test:smtp": "tsx src/scripts/testSmtp.ts",
    "test:smtp:prod": "node dist/scripts/testSmtp.js",
    "setup:ollama": "tsx src/scripts/setupOllama.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx src/scripts/seed.ts",
    "seed:demo": "tsx src/scripts/seedDemo.ts",
    "seed:demo:solo": "tsx src/scripts/seedDemoSolo.ts",
    "seed:dsr": "tsx src/scripts/seedBuildingDsrCli.ts",
    "seed:prod": "node dist/scripts/seed.js",
    "seed:demo:prod": "node dist/scripts/seedDemo.js",
    "seed:demo:solo:prod": "node dist/scripts/seedDemoSolo.js",
    "seed:sync-demo": "tsx src/scripts/seedSyncDemo.ts",
    "seed:sync-demo:prod": "node dist/scripts/seedSyncDemo.js",
    "backfill:activity": "tsx src/scripts/backfillActivity.ts"
  },
  "dependencies": {
    "@esti/contracts": "workspace:*",
    "@hcw/aorms-ai-kit": "workspace:*",
    "@hcw/india-compliance-kit": "workspace:*",
    "@hcw/master-dsr-kit": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "minio": "^8.0.1",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
