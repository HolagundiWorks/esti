{
  "name": "@esti/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    "./router": "./src/trpc/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx src/scripts/seed.ts",
    "seed:demo": "tsx src/scripts/seedDemo.ts",
    "seed:prod": "node dist/scripts/seed.js",
    "seed:demo:prod": "node dist/scripts/seedDemo.js",
    "backfill:activity": "tsx src/scripts/backfillActivity.ts"
  },
  "dependencies": {
    "@esti/contracts": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "minio": "^8.0.1",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
