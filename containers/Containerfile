FROM docker.io/library/php:8.2-apache

LABEL org.opencontainers.image.title="ESTI ERP development runtime"
LABEL org.opencontainers.image.description="Development container for ESTI ERP, a GPL fork based on Dolibarr ERP & CRM"
LABEL org.opencontainers.image.licenses="GPL-3.0-or-later"

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
	&& apt-get install -y --no-install-recommends \
		libfreetype6-dev \
		libicu-dev \
		libjpeg62-turbo-dev \
		libldap2-dev \
		libpng-dev \
		libwebp-dev \
		libxml2-dev \
		libzip-dev \
		mariadb-client \
		unzip \
	&& docker-php-ext-configure gd --with-freetype --with-jpeg --with-webp \
	&& docker-php-ext-configure ldap \
	&& docker-php-ext-install -j"$(nproc)" \
		calendar \
		gd \
		intl \
		ldap \
		mysqli \
		opcache \
		soap \
		zip \
	&& echo "ServerName localhost" > /etc/apache2/conf-available/esti-servername.conf \
	&& a2enmod rewrite headers expires \
	&& a2enconf esti-servername \
	&& rm -rf /var/lib/apt/lists/*

COPY htdocs/ /var/www/html/
COPY containers/php.ini /usr/local/etc/php/conf.d/esti.ini
COPY containers/apache-site.conf /etc/apache2/sites-available/000-default.conf
COPY containers/entrypoint.sh /usr/local/bin/esti-entrypoint
COPY containers/apply-esti-defaults.php /usr/local/bin/apply-esti-defaults.php
COPY containers/install.forced.php /var/www/html/install/install.forced.php

RUN chmod +x /usr/local/bin/esti-entrypoint \
	&& mkdir -p /var/www/documents \
	&& touch /var/www/html/conf/conf.php \
	&& chown -R www-data:www-data /var/www/html/conf /var/www/documents

WORKDIR /var/www/html

ENTRYPOINT ["esti-entrypoint"]
CMD ["apache2-foreground"]
