# ESTI AORMS — environment configuration
#
# Copy to `.env` (next to compose.yaml) and edit before any real deployment.
# `podman compose` / `docker compose` reads `.env` automatically. Every value
# has a safe DEV default baked into compose.yaml, so a local dev pod needs no
# .env — this file matters for PRODUCTION. Generate secrets with:
#     openssl rand -hex 32
#
#   cp .env.example .env  &&  $EDITOR .env

# --- Runtime -----------------------------------------------------------------
NODE_ENV=production
BACKEND_PORT=4000
# Signs session cookies — MUST change for production (>= 16 chars).
SESSION_SECRET=change-me-in-prod-please-32-bytes-min
# Set true when serving over HTTPS (marks the session cookie Secure).
COOKIE_SECURE=true
# Comma-separated browser origins permitted to make cookie-authenticated writes.
ALLOWED_ORIGINS=https://esti.example.com

# --- PostgreSQL (system of record) -------------------------------------------
POSTGRES_USER=esti
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=esti
# Must match the three values above (host `db` = compose service name).
DATABASE_URL=postgres://esti:change-me-strong-db-password@db:5432/esti

# --- Redis (job bus, sessions) -----------------------------------------------
REDIS_URL=redis://redis:6379
WORKER_JOB_STREAM=esti:jobs
WORKER_GROUP=esti-workers

# --- Object storage (MinIO / S3) ---------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_REGION=ap-south-1
S3_BUCKET=esti-documents
S3_ACCESS_KEY=esti
S3_SECRET_KEY=change-me-strong-object-store-secret
# Browser-reachable endpoint used to SIGN download URLs. In production this is
# your public MinIO/S3 host over TLS, e.g. https://files.example.com
S3_PUBLIC_ENDPOINT=http://localhost:9000

# --- Frontend (Vite) ---------------------------------------------------------
VITE_API_URL=http://localhost:4000

# --- Beta form mail (landing → hi@aorms.in) -----------------------------------
# Standard SMTP from your mail host / VPS panel (Hostinger, cPanel, Zoho, etc.).
# SMTP_SECURE=true for port 465 (SSL); false for port 587 (STARTTLS).
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hi@aorms.in
SMTP_PASS=your_mailbox_password
SMTP_FROM="AORMS Beta <hi@aorms.in>"
BETA_REQUEST_NOTIFY_TO=hi@aorms.in

# --- AI Studio — Ollama on-server only (no cloud API keys) -------------------
# Ollama runs in compose (service `ollama` / `esti-ollama`). Pull a model once:
#   podman exec -it esti-ollama ollama pull llama3.2
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# --- First-run owner account (used by `pnpm --filter @esti/backend seed`) -----
SEED_OWNER_EMAIL=owner@hcw.in
SEED_OWNER_PASSWORD=change-me-on-first-login
SEED_OWNER_NAME="HCW Owner"

# --- AORMS identity + licence authority (the Holagundi platform) --------------
# ESTI_ROLE=node is a firm install; it activates/refreshes its licence against
# the central platform at ESTI_LICENSE_API_URL/v1 (default aorms.in). The node
# stays unmanaged (runs on FIRM_PLAN) until a licence is activated, so an empty
# product key is safe. PLATFORM_ADMIN_DOMAINS routes tenant-first Step-1 to the
# platform-admin login (defaults to aorms.in).
ESTI_ROLE=node
ESTI_LICENSE_API_URL=https://aorms.in/platform
ESTI_PRODUCT_API_KEY=
# PLATFORM_ADMIN_DOMAINS=aorms.in
