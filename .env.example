# ESTI AORMS — development environment (copy to .env)

NODE_ENV=development

# Backend
BACKEND_PORT=4000
SESSION_SECRET=change-me-in-prod-please-32-bytes-min
COOKIE_SECURE=false

# PostgreSQL (system of record)
DATABASE_URL=postgres://esti:esti@localhost:5432/esti

# Redis (job bus, sessions, cache)
REDIS_URL=redis://localhost:6379

# Object storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET=esti-documents
S3_ACCESS_KEY=esti
S3_SECRET_KEY=esti-secret

# Frontend (Vite)
VITE_API_URL=http://localhost:4000

# Python worker
WORKER_JOB_STREAM=esti:jobs
WORKER_GROUP=esti-workers
