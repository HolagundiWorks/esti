# Dev image for the worker: only the deps the consumer loop imports today.
# The heavy job libs (ezdxf, WeasyPrint, pandas) come in via the prod Dockerfile
# when the real handlers are implemented.
FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir redis pydantic-settings
COPY worker/ ./
CMD ["python", "-m", "esti_worker.main"]
