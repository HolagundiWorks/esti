# Dev image for the worker. ezdxf (DXF takeoff), boto3, psycopg and pandas are
# pure-wheel installs; WeasyPrint needs the pango/cairo/gdk-pixbuf system libs.
FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential libpango-1.0-0 libpangocairo-1.0-0 libgdk-pixbuf-2.0-0 libffi-dev libcairo2 \
    && rm -rf /var/lib/apt/lists/*
COPY worker/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY worker/ ./
CMD ["python", "-m", "esti_worker.main"]
