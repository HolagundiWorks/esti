{
  "name": "esti-aorms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ESTI — Architectural Office Resource Management System (AORMS) by Holagundi Consulting Works",
  "packageManager": "pnpm@9.7.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @esti/backend db:generate",
    "db:migrate": "pnpm --filter @esti/backend db:migrate",
    "seed:demo": "pnpm --filter @esti/backend seed:demo",
    "seed:demo:solo": "pnpm --filter @esti/backend seed:demo:solo"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0"
  }
}
