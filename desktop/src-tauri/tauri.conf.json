{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ESTI",
  "version": "0.1.0",
  "identifier": "in.aorms.esti",
  "build": {
    "frontendDist": "../../frontend/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "ESTI AORMS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ipc: http://ipc.localhost; img-src 'self' http://127.0.0.1:* http://localhost:* data: blob:; frame-src 'self' http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; font-src 'self' data: https://1.www.s81c.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/esti-backend"],
    "resources": ["resources/backend/**/*"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
