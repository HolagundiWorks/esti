# Keep the legacy Dolibarr tree and other heavy/irrelevant paths out of build context
htdocs/
docs/
containers/
.git/
**/node_modules/
**/dist/
# Vendor kit packages ship pre-built dist/ — override the exclusion above.
# Both the directory and its contents must be explicitly un-excluded.
!vendor/hcw-aorms-ai-kit/dist/
!vendor/hcw-aorms-ai-kit/dist/**
!vendor/hcw-ui-kit/dist/
!vendor/hcw-ui-kit/dist/**
**/.venv/
**/__pycache__/
*.log
.env
