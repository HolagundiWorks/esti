{
  "name": "@esti/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-wiki-knowledge.mjs && tsc -p tsconfig.json && vite build && node scripts/prerender-blog.mjs",
    "sync:wiki-knowledge": "node scripts/sync-wiki-knowledge.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "sync:brand": "python scripts/sync-brand-assets.py",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@esti/backend": "workspace:*",
    "@esti/contracts": "workspace:*",
    "@hcw/ui-kit": "workspace:*",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/urbanist": "^5.2.7",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-charts": "^9.8.0",
    "@mui/x-data-grid": "^9.8.0",
    "@mui/x-date-pickers": "^9.8.0",
    "@tanstack/react-query": "^5.51.0",
    "@tauri-apps/api": "^2.5.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@xyflow/react": "^12.11.2",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "pdfjs-dist": "4.10.38",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "sass": "^1.77.8",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
