# ESTI AORMS frontend (Vite dev server)
# Build context: repo root — @hcw/aorms-ai-kit is vendored under vendor/ (no sibling repos).
#   podman build -f frontend/Dockerfile.dev -t localhost/esti-frontend:dev .
FROM node:20-alpine
ENV IBM_TELEMETRY_DISABLED=true
RUN corepack enable
WORKDIR /app/esti

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./
COPY packages/contracts/package.json packages/contracts/
COPY backend/package.json backend/
COPY frontend/package.json frontend/
COPY vendor vendor/

RUN pnpm install --no-frozen-lockfile --ignore-scripts

COPY packages/contracts packages/contracts
COPY backend backend
COPY frontend frontend

EXPOSE 5173
CMD ["pnpm", "--filter", "@esti/frontend", "dev"]
